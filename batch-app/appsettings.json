{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "GoogleCloud": {
    "ProjectId": ""
  },
  "BatchSettings": {
    "ProcessIntervalMinutes": 5,
    "MaxRetries": 3,
    "RetryDelaySeconds": 30,
    "EnableContinuousProcessing": true
  },
  "FileProcessing": {
    "InputDirectory": "/mnt/gcs-bucket",
    "ProcessedDirectory": "/mnt/gcs-bucket/processed",
    "FailedDirectory": "/mnt/gcs-bucket/failed",
    "FilePattern": "*.csv",
    "DeleteAfterProcessing": false,
    "MaxFilesPerBatch": 10
  },
  "Database": {
    "ConnectionString": "",
    "CommandTimeout": 30,
    "BulkInsertBatchSize": 1000,
    "EnableRetry": true,
    "MaxRetryAttempts": 3
  }
}
